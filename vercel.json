{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\.(js|css|svg|png|ico|woff|woff2))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
